{
  "framework": "vite",
  "root": "artifacts/vestige-index",
  "installCommand": "cd artifacts/vestige-index && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}