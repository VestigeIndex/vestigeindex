# CoinMarketCap API Key (get free at https://coinmarketcap.com/api/)
VITE_COINMARKETCAP_API_KEY=your_cmc_api_key_here

# CryptoCompare API Key (get free at https://www.cryptocompare.com/)
VITE_CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# 1inch API Key (get free at https://1inch.io/)
VITE_ONEINCH_API_KEY=your_1inch_api_key_here

# WalletConnect Project ID (get free at https://cloud.walletconnect.com/)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: Admin credentials for /admin panel
# VITE_ADMIN_USER=admin
# VITE_ADMIN_PASS=your_secure_password
