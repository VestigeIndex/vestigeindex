# API Keys and Configuration for Vestige Index
# Copy this file to .env.local and fill in your values
# DO NOT commit .env files with real keys to version control

# WalletConnect Project ID (Required for wallet connections)
VITE_WALLETCONNECT_PROJECT_ID=9b39025ad1e21900725d77ef50a908cd

# CryptoCompare API Key (For news data)
VITE_CRYPTOCOMPARE_API_KEY=82022d21989d2befebdbaa2a4e001369bfc8b20f00dd661ea90b8fbe9102174f

# Fee Addresses (Hardcoded)
# EVM Commission Address
VITE_EVM_FEE_ADDRESS=0xA1131edb7A6d5E816BF8548078A88a6bF3D91C7F

# Solana Commission Address
VITE_SOL_FEE_ADDRESS=BpazU34aCvMo1oyhhoxj6u3rnWkXjD8j81rKEFJ2oNLt

# Optional: 1inch API Key (if needed for additional swap routes)
ONEINCH_API_KEY=your_1inch_api_key_here

# Optional: CoinMarketCap API Key (alternative data source)
VITE_COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_here

# Admin Credentials (for admin panel)
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=admin

# Data Sources (These are public APIs, no keys required)
# Binance API: https://api.binance.com/api/v3/
# OpenOcean V4: https://open-api.openocean.finance/v4/
# CryptoCompare: https://min-api.cryptocompare.com/
